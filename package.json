{
  "name": "@nejs/jsdoc-react-theme",
  "version": "2.0.0",
  "description": "A modern JSDoc template built with React and Radix UI, inspired by AuthKit",
  "main": "publish.js",
  "bin": {
    "jsdoc-react": "./bin/cli.js"
  },
  "files": [
    "publish.js",
    "build.js",
    "bin/",
    "src/",
    "dist/*.js",
    "dist/*.css"
  ],
  "scripts": {
    "build": "node build.js",
    "build:prod": "node build.js --minify",
    "dev": "node build.js --watch",
    "prepublishOnly": "node build.js --minify",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "jsdoc",
    "jsdoc-template",
    "jsdoc-theme",
    "documentation",
    "radix-ui",
    "react"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "highlight.js": "^11.9.0",
    "jsdoc": "^4.0.0",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/themes": "^3.0.0",
    "esbuild": "^0.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vitest": "^4.0.18"
  }
}